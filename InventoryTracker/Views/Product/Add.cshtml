@model InventoryTracker.Models.Product

<h2>Add Product</h2>

<form asp-action="Add" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StockQuantity" class="form-label"></label>
        <input asp-for="StockQuantity" class="form-control" />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ManufacturerId" class="form-label">Manufacturer</label>
        <select asp-for="ManufacturerId" class="form-select"
                asp-items="@(new SelectList(ViewBag.Manufacturers, "ManufacturerId", "ManufacturerName"))">
            <option value="">-- Select Manufacturer --</option>
        </select>
        <span asp-validation-for="ManufacturerId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Add Product</button>
    <a asp-action="List" class="btn btn-secondary">Cancel</a>
</form>