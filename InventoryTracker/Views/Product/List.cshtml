@model List<InventoryTracker.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Products</h2>
    <a asp-controller="Product" asp-action="Add" class="btn btn-primary">+ Add Product</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Manufacturer</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td class="fw-semibold">@product.Name</td>
                        <td>@product.UserAccount?.AccountName</td>
                        <td>@product.Price.ToString("C")</td>
                        <td>
                            @if (product.StockQuantity == 0)
                            {
                                <span class="badge bg-danger">Out of Stock</span>
                            }
                            else if (product.StockQuantity < 10)
                            {
                                <span class="badge bg-warning text-dark">Low: @product.StockQuantity</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@product.StockQuantity</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="Product" asp-action="Index"
                               asp-route-id="@product.ProductId"
                               class="btn btn-sm btn-outline-primary">View Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}