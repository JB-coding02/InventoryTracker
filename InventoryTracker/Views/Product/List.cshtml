@model List<InventoryTracker.Models.Product>

<h2>Products</h2>

@if (Model.Count == 0)
{
    <p>No products found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Manufacturer</th>
                <th>Price</th>
                <th>Stock</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Manufacturer?.ManufacturerName</td>
                    <td>@product.Price.ToString("C")</td>
                    <td>@product.StockQuantity</td>
                    <td>
                        <a asp-controller="Product" asp-action="Index" asp-route-id="@product.ProductId">
                            View Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}