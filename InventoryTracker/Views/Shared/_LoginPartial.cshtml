@using Microsoft.AspNetCore.Identity
@using InventoryTracker.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = currentUser?.CompanyName;
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = UserManager.GetUserName(User);
    }

    <li class="nav-item">
        <a class="nav-link text-dark"
           asp-area="Identity"
           asp-page="/Account/Manage/Index"
           title="Manage">Hello @displayName!</a>
    </li>

    <li class="nav-item">
        <form class="form-inline"
              method="post"
              asp-area="Identity"
              asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Content("~/")">
            <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
        </form>
    </li>

    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Profile" asp-action="Index">My Profile</a>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login">Login</a>
    </li>
}
</ul>
