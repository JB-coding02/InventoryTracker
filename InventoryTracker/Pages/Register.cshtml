@page
@model InventoryTracker.Pages.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title mb-3">Create an account</h3>

                <form method="post" novalidate>
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Input.AccountType" class="form-label">Account type</label>
                        <select asp-for="Input.AccountType" class="form-select" id="accountTypeSelect">
                            <option value="Manufacturer">Manufacturer</option>
                            <option value="Wholesaler">Wholesaler</option>
                        </select>
                        <span asp-validation-for="Input.AccountType" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label id="companyLabel" asp-for="Input.CompanyName" class="form-label">Manufacturer name</label>
                        <input asp-for="Input.CompanyName" class="form-control" placeholder="Enter company name" />
                        <span asp-validation-for="Input.CompanyName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Company email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="name@company.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <input asp-for="Input.Password" class="form-control" />
                        <div class="form-text">@Model.PasswordRequirements</div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Confirm password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Register</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />

<script>
    (function () {
        const select = document.getElementById('accountTypeSelect');
        const companyLabel = document.getElementById('companyLabel');

        function updateLabel() {
            if (!select || !companyLabel) return;
            companyLabel.textContent = select.value === 'Wholesaler' ? 'Wholesaler name' : 'Manufacturer name';
        }

        select?.addEventListener('change', updateLabel);
        updateLabel();
    })();
</script>
